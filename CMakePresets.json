{
	"version": 6,
	"cmakeMinimumRequired": { "major": 3, "minor": 31, "patch": 0 },

	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"CMAKE_COLOR_DIAGNOSTICS": "ON"
			}
		},
		{
			"name": "debug",
			"displayName": "Debug",
			"description": "Debug build with tests",
			"inherits": "base",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"COMPILER_ENABLE_TESTING": "ON"
			}
		},
		{
			"name": "release",
			"displayName": "Release",
			"inherits": "base",
			"binaryDir": "${sourceDir}/build/release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
			}
		},
		{
			"name": "asan",
			"displayName": "ASan + UBSan",
			"description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
			"inherits": "base",
			"binaryDir": "${sourceDir}/build/asan",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"COMPILER_ENABLE_TESTING": "ON",
				"COMPILER_ENABLE_ASAN": "ON",
				"COMPILER_ENABLE_UBSAN": "ON"
			}
		},
		{
			"name": "ci",
			"displayName": "CI",
			"description": "Release build with warnings as errors and tests",
			"inherits": "base",
			"binaryDir": "${sourceDir}/build/ci",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"COMPILER_ENABLE_TESTING": "ON",
				"COMPILER_WARNINGS_AS_ERRORS": "ON"
			}
		},
		{
			"name": "tidy",
			"displayName": "Clang-Tidy",
			"description": "Debug build with clang-tidy enabled",
			"inherits": "base",
			"binaryDir": "${sourceDir}/build/tidy",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"COMPILER_ENABLE_CLANG_TIDY": "ON"
			}
		}
	],

	"buildPresets": [
		{ "name": "debug",   "configurePreset": "debug"   },
		{ "name": "release", "configurePreset": "release"  },
		{ "name": "asan",    "configurePreset": "asan"     },
		{ "name": "ci",      "configurePreset": "ci"       },
		{ "name": "tidy",    "configurePreset": "tidy"     }
	],

	"testPresets": [
		{
			"name": "debug",
			"configurePreset": "debug",
			"output": { "outputOnFailure": true }
		},
		{
			"name": "asan",
			"configurePreset": "asan",
			"output": { "outputOnFailure": true }
		},
		{
			"name": "ci",
			"configurePreset": "ci",
			"output": { "outputOnFailure": true }
		}
	],

	"workflowPresets": [
		{
			"name": "debug",
			"steps": [
				{ "type": "configure", "name": "debug" },
				{ "type": "build",     "name": "debug" },
				{ "type": "test",      "name": "debug" }
			]
		},
		{
			"name": "asan",
			"steps": [
				{ "type": "configure", "name": "asan"  },
				{ "type": "build",     "name": "asan"  },
				{ "type": "test",      "name": "asan"  }
			]
		},
		{
			"name": "ci",
			"steps": [
				{ "type": "configure", "name": "ci"    },
				{ "type": "build",     "name": "ci"    },
				{ "type": "test",      "name": "ci"    }
			]
		},
		{
			"name": "tidy",
			"steps": [
				{ "type": "configure", "name": "tidy"  },
				{ "type": "build",     "name": "tidy"  }
			]
		}
	]
}
